version: '3.8'

services:
  # Frontend сервис
  frontend:
    image: ${DOCKER_USERNAME}/web-app-frontend:latest
    container_name: frontend
    ports:
      - '${FRONTEND_PORT:-3000}:80'
    environment:
      - VITE_API_URL=${VITE_API_URL:-https://${DOMAIN:-supermock.ru}/api}
      - VITE_BACKEND_URL=https://${DOMAIN:-supermock.ru}
    depends_on:
      - backend
    networks:
      - app-network
    restart: always
    logging:
      driver: 'json-file'
      options:
        max-size: '10m'
        max-file: '3'

  # Backend сервис
  backend:
    image: ${DOCKER_USERNAME}/web-app-backend:latest
    container_name: backend
    ports:
      - '${BACKEND_PORT:-4000}:4000'
    environment:
      - PORT=${PORT:-9095}
      - MONGO_URI=${MONGO_URI:-mongodb://${MONGO_INITDB_ROOT_USERNAME:-admin}:${MONGO_INITDB_ROOT_PASSWORD:-krishna1284radha}@mongo:27017/${MONGO_DB_NAME:-mock_interviews}?authSource=admin}
      - REDIS_HOST=redis
      - REDIS_PORT=6379
      - REDIS_PASSWORD=${REDIS_PASSWORD:-password123}
      - NODE_ENV=${NODE_ENV:-production}
    depends_on:
      - mongo
      - redis
    networks:
      - app-network
    restart: always
    logging:
      driver: 'json-file'
      options:
        max-size: '10m'
        max-file: '3'

  # MongoDB сервис
  mongo:
    image: mongo:5
    container_name: mongo
    volumes:
      - mongo-data:/data/db
    environment:
      - MONGO_INITDB_ROOT_USERNAME=${MONGO_INITDB_ROOT_USERNAME:-admin}
      - MONGO_INITDB_ROOT_PASSWORD=${MONGO_INITDB_ROOT_PASSWORD:-krishna1284radha}
    networks:
      - app-network
    restart: always
    logging:
      driver: 'json-file'
      options:
        max-size: '10m'
        max-file: '3'

  # Redis сервис
  redis:
    image: redis:7-alpine
    container_name: redis
    volumes:
      - redis-data:/data
    command: redis-server --requirepass ${REDIS_PASSWORD:-krishna1284radha} --appendonly yes
    networks:
      - app-network
    restart: always
    logging:
      driver: 'json-file'
      options:
        max-size: '10m'
        max-file: '3'

  # Nginx сервис (reverse proxy)
  nginx:
    image: nginx:stable-alpine
    container_name: nginx
    ports:
      - '${NGINX_PORT:-80}:80'
      - '443:443'
    volumes:
      - ./nginx/nginx.conf:/etc/nginx/conf.d/default.conf
      - ./backend/letsencrypt:/etc/letsencrypt
    depends_on:
      - frontend
      - backend
    networks:
      - app-network
    restart: always
    logging:
      driver: 'json-file'
      options:
        max-size: '10m'
        max-file: '3'

volumes:
  mongo-data:
  redis-data:

networks:
  app-network:
    driver: bridge
